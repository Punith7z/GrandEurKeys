<style>
/* Chatbot Logo & Size Overrides */
.chatbot-launcher {
    width: 64px !important;
    height: 64px !important;
    background: linear-gradient(135deg, #050505, #1a1a1a) !important;
    border: 2px solid rgba(255, 255, 255, 0.1) !important;
    box-shadow: 0 15px 30px rgba(0,0,0,0.5) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    bottom: 32px !important;
    right: 32px !important;
}
.chatbot-launcher svg {
    color: #00ff88;
    transition: transform 0.3s ease;
}
.chatbot-launcher:hover svg {
    transform: scale(1.1) rotate(180deg);
}
.chatbot-container {
    bottom: 110px !important;
    right: 32px !important;
}
@media (max-width: 768px) {
    .chatbot-launcher {
        bottom: 16px !important;
        right: 16px !important;
        width: 56px !important;
        height: 56px !important;
    }
    .chatbot-container {
        bottom: 84px !important;
        right: 16px !important;
        width: calc(100vw - 32px) !important;
        height: 65vh !important;
    }
}
</style>

<button class="chatbot-launcher" id="chatbotLauncher" aria-label="Toggle AI Concierge">
    <!-- Beautiful Geometric AI Sparkle Logo -->
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12a9 9 0 0 0-9-9 9 9 0 0 0-9 9 9 9 0 0 0 9 9 9 9 0 0 0 9-9Z"></path>
        <path d="M12 7v10"></path>
        <path d="M8 10l8 4"></path>
        <path d="M8 14l8-4"></path>
    </svg>
</button>

<div class="chatbot-container hidden" id="chatbotContainer">
    <div class="chatbot-header">
        <div class="header-profile">
            <div class="profile-avatar" style="background: #111; border: 1px solid rgba(255,255,255,0.2);">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12a9 9 0 0 0-9-9 9 9 0 0 0-9 9 9 9 0 0 0 9 9 9 9 0 0 0 9-9Z"></path>
                    <path d="M12 7v10"></path>
                    <path d="M8 10l8 4"></path>
                    <path d="M8 14l8-4"></path>
                </svg>
            </div>
            <div class="profile-info">
                <h4>Grandeur Concierge</h4>
                <p>AI Travel Assistant</p>
            </div>
        </div>
        <button class="chatbot-close" id="chatbotClose" aria-label="Close Chat">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </div>

    <!-- Active Message Conversation Stream -->
    <div class="chatbot-messages" id="chatbotMessages">
        <div class="message incoming">
            <div class="message-content">
                Welcome to Grandeur Keys. I am your personal AI Concierge. How may I help you curate your next escape?
            </div>
        </div>
    </div>

    <!-- Interactive Starter Recommendation Suggestions -->
    <div class="chatbot-suggestions" id="chatbotSuggestions">
        <button class="suggestion-pill" data-prompt="Show me modern luxury hotels in the city.">🏢 Skyline Hotels</button>
        <button class="suggestion-pill" data-prompt="Find me secluded wellness resorts.">🏝️ Secluded Resorts</button>
        <button class="suggestion-pill" data-prompt="What amenities do you offer?">✨ Amenities</button>
    </div>

    <!-- Standard Text Input and Action Panel -->
    <div class="chatbot-input-panel">
        <input type="text" id="chatbotInput" placeholder="Ask about destinations, pricing..." aria-label="Chat Message">
        <button id="chatbotSend" class="send-btn" aria-label="Send Message">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
        </button>
    </div>
</div>