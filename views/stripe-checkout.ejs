<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout | Grandeur Keys Secure</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            background-color: #050505; /* Deep futuristic black */
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(45, 20, 80, 0.4), transparent 50%),
                radial-gradient(circle at 85% 30%, rgba(20, 60, 80, 0.4), transparent 50%);
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        * { box-sizing: border-box; }

        /* Full layout container */
        .checkout-wrapper {
            display: flex;
            width: 100%;
            max-width: 1100px;
            min-height: 700px;
            margin: 40px;
            background: rgba(25, 25, 25, 0.4);
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 32px;
            box-shadow: 0 40px 100px rgba(0, 0, 0, 0.8), inset 0 1px 0 rgba(255, 255, 255, 0.1);
            overflow: hidden;
            position: relative;
            z-index: 10;
            transform-style: preserve-3d;
            perspective: 1200px;
        }

        /* 3D Tilt Script will target this */
        .checkout-wrapper.tilt {
            transition: transform 0.1s ease-out;
        }

        /* Ambient glowing line at the top */
        .checkout-wrapper::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(140, 100, 255, 0.8), rgba(0, 200, 255, 0.8), transparent);
            z-index: 20;
        }

        /* Left Side: Order Details (Translucent Dark) */
        .order-panel {
            width: 45%;
            padding: 60px;
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            background: rgba(10, 10, 10, 0.3);
        }

        .merchant-name {
            font-weight: 300;
            font-size: 20px;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 12px;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .price-display {
            margin-bottom: 40px;
        }

        .amount-due {
            color: rgba(255, 255, 255, 0.5);
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .grand-total {
            font-size: 48px;
            font-weight: 300;
            color: #ffffff;
            letter-spacing: -1px;
        }

        .item-list {
            flex-grow: 1;
        }

        .item {
            display: flex;
            align-items: center;
            margin-bottom: 24px;
            padding-bottom: 24px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .item-img {
            width: 72px;
            height: 72px;
            border-radius: 16px;
            object-fit: cover;
            margin-right: 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .item-details {
            flex-grow: 1;
        }

        .item-title {
            font-weight: 400;
            font-size: 15px;
            margin: 0 0 6px 0;
            letter-spacing: 0.5px;
        }

        .item-desc {
            color: rgba(255, 255, 255, 0.5);
            font-size: 13px;
            margin: 0 0 8px 0;
        }

        .item-price {
            font-weight: 300;
            font-size: 15px;
        }

        /* Right Side: Payment Form (Minimal Dark) */
        .payment-panel {
            width: 55%;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .payment-content {
            width: 100%;
            max-width: 400px;
            margin: 0 auto;
        }

        .section-title {
            font-size: 20px;
            font-weight: 300;
            margin-bottom: 32px;
            color: #ffffff;
            letter-spacing: 1px;
        }

        .form-group {
            margin-bottom: 24px;
        }

        .form-label {
            display: block;
            font-size: 12px;
            font-weight: 500;
            margin-bottom: 10px;
            color: rgba(255, 255, 255, 0.6);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .stripe-input {
            width: 100%;
            height: 52px;
            padding: 14px 20px;
            font-size: 15px;
            font-family: inherit;
            color: #ffffff;
            background-color: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            transition: all 0.3s ease;
        }

        .stripe-input:focus {
            outline: none;
            background-color: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.3);
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.05);
        }
        
        .stripe-input::placeholder { color: rgba(255, 255, 255, 0.2); }

        .card-element {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 32px;
        }

        .card-row-split {
            display: flex;
            gap: 12px;
        }

        .pay-button {
            width: 100%;
            height: 56px;
            background: linear-gradient(135deg, #ffffff, #dcdcdc);
            color: #000000;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 20px rgba(255, 255, 255, 0.1);
        }

        .pay-button:hover { 
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(255, 255, 255, 0.2);
        }
        
        .pay-button:disabled { 
            background: rgba(255, 255, 255, 0.1); 
            color: rgba(255, 255, 255, 0.3);
            cursor: not-allowed; 
            transform: none;
            box-shadow: none;
        }

        .terms {
            margin-top: 32px;
            font-size: 12px;
            color: rgba(255, 255, 255, 0.3);
            line-height: 1.6;
            text-align: center;
        }

        .error-message {
            background: rgba(223, 27, 65, 0.1);
            color: #ff4a6b;
            padding: 16px;
            border-radius: 12px;
            font-size: 13px;
            margin-bottom: 24px;
            display: none;
            border: 1px solid rgba(223, 27, 65, 0.3);
        }

        /* Mobile Responsive */
        @media (max-width: 900px) {
            .checkout-wrapper { flex-direction: column; margin: 20px; border-radius: 24px; min-height: auto; }
            .order-panel, .payment-panel { width: 100%; padding: 40px 24px; }
            .order-panel { border-right: none; border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
        }
        @media (max-width: 480px) {
            .checkout-wrapper { margin: 8px; border-radius: 16px; }
            .order-panel, .payment-panel { padding: 32px 16px; }
            .merchant-name { margin-bottom: 24px; }
            .price-display { margin-bottom: 24px; }
            .grand-total { font-size: 32px; }
            .section-title { margin-bottom: 24px; }
        }
    </style>
</head>
<body>

<div class="checkout-wrapper" id="tiltContainer">
    <!-- Left Panel -->
    <div class="order-panel">
        <div class="merchant-name">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            Grandeur Keys
        </div>

        <div class="price-display">
            <div class="amount-due">Authorized Amount</div>
            <div class="grand-total">$<%= bill.grandTotal.toLocaleString() %></div>
        </div>

        <div class="item-list">
            <% cart.forEach(segment => { %>
            <div class="item">
                <img src="<%= segment.propertyImage %>" class="item-img" alt="<%= segment.propertyName %>">
                <div class="item-details">
                    <p class="item-title"><%= segment.propertyName %></p>
                    <p class="item-desc"><%= segment.totalNights %> Nights • <%= segment.guests %> Guests</p>
                    <div class="item-price">
                        $<%= segment.pricingBreakdown.finalPrice.toLocaleString() %>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>

    <!-- Right Panel -->
    <div class="payment-panel">
        <div class="payment-content">
            <h2 class="section-title">Encrypted Checkout</h2>
            
            <div class="error-message" id="errorMessage"></div>

            <form id="stripeMockForm">
                <div class="form-group">
                    <label class="form-label">Client Email</label>
                    <input type="email" id="email" class="stripe-input" placeholder="you@private-domain.com" required>
                </div>

                <div class="card-element">
                    <div>
                        <label class="form-label">Card Number</label>
                        <input type="text" id="cardNumber" class="stripe-input" placeholder="0000 0000 0000 0000" maxlength="19" required autocomplete="cc-number">
                    </div>
                    <div class="card-row-split">
                        <div style="flex: 1;">
                            <label class="form-label">Expiry</label>
                            <input type="text" id="cardExpiry" class="stripe-input" placeholder="MM / YY" maxlength="5" required autocomplete="cc-exp">
                        </div>
                        <div style="flex: 1;">
                            <label class="form-label">CVC</label>
                            <input type="password" id="cardCvc" class="stripe-input" placeholder="•••" maxlength="4" required autocomplete="cc-csc">
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Name on Card</label>
                    <input type="text" id="cardName" class="stripe-input" placeholder="Julian Vance" required autocomplete="cc-name">
                </div>

                <button type="submit" id="submitBtn" class="pay-button">
                    Initialize Payment • $<%= bill.grandTotal.toLocaleString() %>
                </button>

                <div class="terms">
                    Protected by AES-256 military-grade encryption. Grandeur Keys does not store your raw payment details. By authorizing this payment, you agree to our Terms of Residency.
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // 3D Tilt Effect logic
    const container = document.getElementById('tiltContainer');
    
    // Disable 3D tilt on mobile
    if (window.innerWidth > 900) {
        document.addEventListener('mousemove', (e) => {
            const maxTilt = 4; // Subtler tilt for large checkout
            const rect = container.getBoundingClientRect();
            
            // Only tilt if mouse is roughly around the container to save performance
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            
            const rotateX = ((y - centerY) / centerY) * -maxTilt;
            const rotateY = ((x - centerX) / centerX) * maxTilt;
            
            container.style.transform = `perspective(1200px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
        });

        document.addEventListener('mouseleave', () => {
            container.style.transform = `perspective(1200px) rotateX(0deg) rotateY(0deg)`;
            container.style.transition = 'transform 0.5s ease-out';
        });
    }

    // Payment Form Handler
    document.getElementById('stripeMockForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = 'Establishing Secure Connection...';

        try {
            // Wait a moment for dramatic futuristic effect
            await new Promise(res => setTimeout(res, 800));
            btn.innerHTML = 'Processing Transaction...';

            const response = await fetch('/checkout/pay', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    cardHolder: document.getElementById('cardName').value,
                    email: document.getElementById('email').value
                })
            });

            const data = await response.json();
            
            if (response.ok && data.redirectUrl) {
                btn.innerHTML = 'Authorization Successful';
                btn.style.background = 'linear-gradient(135deg, #00ff88, #00b35f)';
                btn.style.color = '#fff';
                btn.style.boxShadow = '0 10px 30px rgba(0, 255, 136, 0.4)';
                
                setTimeout(() => {
                    window.location.href = data.redirectUrl;
                }, 1000);
            } else {
                throw new Error('Bank authorization failed. Please verify credentials.');
            }
        } catch (err) {
            btn.disabled = false;
            btn.innerHTML = 'Initialize Payment • $<%= bill.grandTotal.toLocaleString() %>';
            const errorEl = document.getElementById('errorMessage');
            errorEl.innerText = err.message;
            errorEl.style.display = 'block';
        }
    });

    // Formatting Inputs
    document.getElementById('cardNumber').addEventListener('input', function (e) {
        let value = e.target.value.replace(/\s+/g, '').replace(/[^0-9]/gi, '');
        let formattedValue = '';
        for (let i = 0; i < value.length; i++) {
            if (i > 0 && i % 4 === 0) formattedValue += ' ';
            formattedValue += value[i];
        }
        e.target.value = formattedValue;
    });

    document.getElementById('cardExpiry').addEventListener('input', function (e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length > 2) value = value.substring(0, 2) + ' / ' + value.substring(2, 4);
        e.target.value = value;
    });
</script>
</body>
</html>
